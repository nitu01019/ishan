# Admin
ADMIN_PASSWORD=your_admin_password
# Separate secret used to sign session tokens (recommended: 32+ random bytes as hex)
# If not set, falls back to ADMIN_PASSWORD — set this explicitly in production.
SESSION_SECRET=your_session_signing_secret

# Supabase (required for database + file uploads)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Storage setup:
#   1. Go to Supabase Dashboard → Storage → New Bucket
#   2. Create a bucket named "uploads" (set as public for public URLs)
#   3. Go to Policies → Add new policy for "uploads" bucket
#   4. Allow INSERT for anon role (enables direct browser uploads)
#   5. Allow SELECT for anon role (enables public file access)

# Optional
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_VERIFICATION=your_google_verification_code
